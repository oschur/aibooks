POSTGRES_DB=aibooks
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
AIBOOKS_DB_URL=postgres://postgres:postgres@localhost:5432/aibooks?sslmode=disable

AIBOOKS_REDIS_ADDR=127.0.0.1:6379
AIBOOKS_REDIS_DB=0
AIBOOKS_LOG_DIR=logs
AIBOOKS_LOG_KAFKA_BROKERS=127.0.0.1:9092
AIBOOKS_LOG_KAFKA_TOPIC=aibooks.logs

AIBOOKS_OCR_LANG=rus
AIBOOKS_PDF_DPI=300
AIBOOKS_DATA_DIR=data
AIBOOKS_TEMP_DIR=tmp

AIBOOKS_EMBEDDING_PROVIDER=gigachat
AIBOOKS_EMBEDDING_MODEL=Embeddings
AIBOOKS_EMBEDDING_DIMENSION=1536
AIBOOKS_GIGACHAT_AUTH_KEY=replace-with-gigachat-basic-auth-key
AIBOOKS_GIGACHAT_SCOPE=GIGACHAT_API_PERS
AIBOOKS_GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
AIBOOKS_GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
AIBOOKS_GIGACHAT_INSECURE_SKIP_VERIFY=true

AIBOOKS_LLM_PROVIDER=deepseek
AIBOOKS_LLM_MODEL=deepseek-chat
AIBOOKS_DEEPSEEK_API_KEY=replace-with-real-key

AIBOOKS_AUTH_SECRET=replace-with-long-random-secret
AIBOOKS_AUTH_TOKEN_TTL_MIN=1440
